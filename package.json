{
  "name": "daily-haiku",
  "version": "1.0.0",
  "description": "Motivational haiku popup app for Windows",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build-portable": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.dailyhaiku.app",
    "productName": "Daily Haiku",
    "win": {
      "target": ["nsis"],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": ["main.js", "preload.js", "index.html"]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}