{
  "name": "daily-haiku",
  "version": "1.0.0",
  "description": "A calm desktop haiku ritual for mindful active-hour pauses.",
  "author": "Daily Haiku",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "electron-builder --dir",
    "build": "electron-builder",
    "dist": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "build-portable": "npm run build:portable"
  },
  "build": {
    "appId": "com.stillhour.app",
    "productName": "StillHour",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "src/**/*",
      "assets/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "vitest": "^4.1.5"
  }
}
